{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "yield-showcase-app",
  "version": "1.0.0",
  "identifier": "com.yieldshowcase.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Yield Showcase",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "android": {
        "icon": "icons/icon.png"
      }
    },
    "android": {
      "packageName": "com.yieldshowcase.app",
      "minSdkVersion": 21,
      "targetSdkVersion": 33
    }
  }
}